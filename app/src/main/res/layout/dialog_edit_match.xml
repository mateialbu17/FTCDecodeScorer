<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:cardBackgroundColor="#1A1A1A"
    app:cardCornerRadius="32dp"
    app:cardElevation="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="#222222">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="EDIT MATCH"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:layout_marginBottom="12dp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">
                <TextView android:id="@+id/tvEditTotalScore" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#03DAC5" android:textSize="32sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" PTS" android:textColor="#888888" android:textSize="14sp" android:layout_marginBottom="4dp"/>
                <View android:layout_width="1dp" android:layout_height="24dp" android:background="#444444" android:layout_marginHorizontal="16dp"/>
                <TextView android:id="@+id/tvEditRP" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#FFC107" android:textSize="32sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" RP" android:textColor="#888888" android:textSize="14sp" android:layout_marginBottom="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="24dp">

                <androidx.cardview.widget.CardView android:id="@+id/editCardAuto" android:layout_width="match_parent" android:layout_height="wrap_content" app:cardBackgroundColor="#2C2C2E" app:cardCornerRadius="20dp" android:layout_marginBottom="16dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                        <TextView android:text="AUTONOMOUS" android:textColor="#BB86FC" android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="12dp"/>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp">
                            <CheckBox android:id="@+id/editCbLeave1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Robot 1 Leave" android:textColor="#FFFFFF" android:buttonTint="#BB86FC"/>
                            <CheckBox android:id="@+id/editCbLeave2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Robot 2 Leave" android:textColor="#FFFFFF" android:buttonTint="#BB86FC" android:layout_marginStart="16dp"/>
                        </LinearLayout>
                        <LinearLayout android:id="@+id/editIncAutoClassified" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="4dp"><TextView android:id="@+id/tvLabel" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Classified" android:textColor="#FFFFFF"/><TextView android:id="@+id/btnMinus" android:layout_width="40dp" android:layout_height="40dp" android:text="&#x2212;" android:background="@drawable/bg_button_round" android:backgroundTint="#444444" android:textColor="#FFFFFF" android:gravity="center" android:textSize="26sp"/><TextView android:id="@+id/tvValue" android:layout_width="32dp" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:gravity="center" android:textStyle="bold"/><TextView android:id="@+id/btnPlus" android:layout_width="40dp" android:layout_height="40dp" android:text="+" android:background="@drawable/bg_button_round" android:backgroundTint="#03DAC5" android:textColor="#000000" android:gravity="center" android:textSize="26sp"/></LinearLayout>
                        <LinearLayout android:id="@+id/editIncAutoOverflow" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="4dp"><TextView android:id="@+id/tvLabel" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Overflow" android:textColor="#FFFFFF"/><TextView android:id="@+id/btnMinus" android:layout_width="40dp" android:layout_height="40dp" android:text="&#x2212;" android:background="@drawable/bg_button_round" android:backgroundTint="#444444" android:textColor="#FFFFFF" android:gravity="center" android:textSize="26sp"/><TextView android:id="@+id/tvValue" android:layout_width="32dp" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:gravity="center" android:textStyle="bold"/><TextView android:id="@+id/btnPlus" android:layout_width="40dp" android:layout_height="40dp" android:text="+" android:background="@drawable/bg_button_round" android:backgroundTint="#03DAC5" android:textColor="#000000" android:gravity="center" android:textSize="26sp"/></LinearLayout>
                        <LinearLayout android:id="@+id/editIncAutoPattern" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="4dp"><TextView android:id="@+id/tvLabel" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Pattern" android:textColor="#FFFFFF"/><TextView android:id="@+id/btnMinus" android:layout_width="40dp" android:layout_height="40dp" android:text="&#x2212;" android:background="@drawable/bg_button_round" android:backgroundTint="#444444" android:textColor="#FFFFFF" android:gravity="center" android:textSize="26sp"/><TextView android:id="@+id/tvValue" android:layout_width="32dp" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:gravity="center" android:textStyle="bold"/><TextView android:id="@+id/btnPlus" android:layout_width="40dp" android:layout_height="40dp" android:text="+" android:background="@drawable/bg_button_round" android:backgroundTint="#03DAC5" android:textColor="#000000" android:gravity="center" android:textSize="26sp"/></LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView android:id="@+id/editCardTeleop" android:layout_width="match_parent" android:layout_height="wrap_content" app:cardBackgroundColor="#2C2C2E" app:cardCornerRadius="20dp" android:layout_marginBottom="16dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                        <TextView android:text="TELEOP" android:textColor="#03DAC5" android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="12dp"/>
                        <LinearLayout android:id="@+id/editIncTeleopClassified" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="4dp"><TextView android:id="@+id/tvLabel" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Classified" android:textColor="#FFFFFF"/><TextView android:id="@+id/btnMinus" android:layout_width="40dp" android:layout_height="40dp" android:text="&#x2212;" android:background="@drawable/bg_button_round" android:backgroundTint="#444444" android:textColor="#FFFFFF" android:gravity="center" android:textSize="26sp"/><TextView android:id="@+id/tvValue" android:layout_width="32dp" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:gravity="center" android:textStyle="bold"/><TextView android:id="@+id/btnPlus" android:layout_width="40dp" android:layout_height="40dp" android:text="+" android:background="@drawable/bg_button_round" android:backgroundTint="#03DAC5" android:textColor="#000000" android:gravity="center" android:textSize="26sp"/></LinearLayout>
                        <LinearLayout android:id="@+id/editIncTeleopOverflow" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="4dp"><TextView android:id="@+id/tvLabel" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Overflow" android:textColor="#FFFFFF"/><TextView android:id="@+id/btnMinus" android:layout_width="40dp" android:layout_height="40dp" android:text="&#x2212;" android:background="@drawable/bg_button_round" android:backgroundTint="#444444" android:textColor="#FFFFFF" android:gravity="center" android:textSize="26sp"/><TextView android:id="@+id/tvValue" android:layout_width="32dp" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:gravity="center" android:textStyle="bold"/><TextView android:id="@+id/btnPlus" android:layout_width="40dp" android:layout_height="40dp" android:text="+" android:background="@drawable/bg_button_round" android:backgroundTint="#03DAC5" android:textColor="#000000" android:gravity="center" android:textSize="26sp"/></LinearLayout>
                        <LinearLayout android:id="@+id/editIncTeleopDepot" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="4dp"><TextView android:id="@+id/tvLabel" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Depot" android:textColor="#FFFFFF"/><TextView android:id="@+id/btnMinus" android:layout_width="40dp" android:layout_height="40dp" android:text="&#x2212;" android:background="@drawable/bg_button_round" android:backgroundTint="#444444" android:textColor="#FFFFFF" android:gravity="center" android:textSize="26sp"/><TextView android:id="@+id/tvValue" android:layout_width="32dp" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:gravity="center" android:textStyle="bold"/><TextView android:id="@+id/btnPlus" android:layout_width="40dp" android:layout_height="40dp" android:text="+" android:background="@drawable/bg_button_round" android:backgroundTint="#03DAC5" android:textColor="#000000" android:gravity="center" android:textSize="26sp"/></LinearLayout>
                        <LinearLayout android:id="@+id/editIncTeleopPattern" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="4dp"><TextView android:id="@+id/tvLabel" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Pattern" android:textColor="#FFFFFF"/><TextView android:id="@+id/btnMinus" android:layout_width="40dp" android:layout_height="40dp" android:text="&#x2212;" android:background="@drawable/bg_button_round" android:backgroundTint="#444444" android:textColor="#FFFFFF" android:gravity="center" android:textSize="26sp"/><TextView android:id="@+id/tvValue" android:layout_width="32dp" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:gravity="center" android:textStyle="bold"/><TextView android:id="@+id/btnPlus" android:layout_width="40dp" android:layout_height="40dp" android:text="+" android:background="@drawable/bg_button_round" android:backgroundTint="#03DAC5" android:textColor="#000000" android:gravity="center" android:textSize="26sp"/></LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView android:id="@+id/editCardEndgame" android:layout_width="match_parent" android:layout_height="wrap_content" app:cardBackgroundColor="#2C2C2E" app:cardCornerRadius="20dp" android:layout_marginBottom="16dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                        <TextView android:text="ENDGAME" android:textColor="#FF5252" android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>
                        <TextView android:text="Robot 1 Park" android:textColor="#888888" android:textSize="12sp"/>
                        <RadioGroup android:id="@+id/editRgPark1" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                            <RadioButton android:id="@+id/editRbPark1None" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="None" android:textColor="#FFFFFF" android:buttonTint="#FF5252"/>
                            <RadioButton android:id="@+id/editRbPark1Part" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Part" android:textColor="#FFFFFF" android:buttonTint="#FF5252"/>
                            <RadioButton android:id="@+id/editRbPark1Full" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Full" android:textColor="#FFFFFF" android:buttonTint="#FF5252"/>
                        </RadioGroup>
                        <LinearLayout android:id="@+id/editLayoutPark2" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginTop="8dp">
                            <TextView android:text="Robot 2 Park" android:textColor="#888888" android:textSize="12sp"/>
                            <RadioGroup android:id="@+id/editRgPark2" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                                <RadioButton android:id="@+id/editRbPark2None" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="None" android:textColor="#FFFFFF" android:buttonTint="#FF5252"/>
                                <RadioButton android:id="@+id/editRbPark2Part" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Part" android:textColor="#FFFFFF" android:buttonTint="#FF5252"/>
                                <RadioButton android:id="@+id/editRbPark2Full" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Full" android:textColor="#FFFFFF" android:buttonTint="#FF5252"/>
                            </RadioGroup>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView android:id="@+id/editCardResult" android:layout_width="match_parent" android:layout_height="wrap_content" app:cardBackgroundColor="#2C2C2E" app:cardCornerRadius="20dp" android:layout_marginBottom="16dp">
                    <RadioGroup android:id="@+id/editRgResult" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="12dp">
                        <RadioButton android:id="@+id/editRbWin" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="WIN" android:textColor="#FFFFFF" android:buttonTint="#34C759"/>
                        <RadioButton android:id="@+id/editRbTie" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="TIE" android:textColor="#FFFFFF" android:buttonTint="#FFCC00"/>
                        <RadioButton android:id="@+id/editRbLoss" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="LOSS" android:textColor="#FFFFFF" android:buttonTint="#FF3B30"/>
                    </RadioGroup>
                </androidx.cardview.widget.CardView>

                <EditText android:id="@+id/editEtNotes" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="80dp" android:hint="Match Notes..." android:textColor="#FFFFFF" android:textColorHint="#888888" android:background="@drawable/bg_button_round" android:backgroundTint="#2C2C2E" android:padding="16dp" android:gravity="top|start"/>
            </LinearLayout>
        </ScrollView>

        <TextView
            android:id="@+id/btnSaveEdit"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="SAVE CHANGES"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_round"
            android:backgroundTint="#0A7AFF"
            android:textColor="#FFFFFF"
            android:layout_margin="16dp"
            android:gravity="center"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>