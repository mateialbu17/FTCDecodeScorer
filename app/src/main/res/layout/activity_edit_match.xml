<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <androidx.cardview.widget.CardView
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardBackgroundColor="#1A1A1A"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/btnBackEdit"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="?attr/homeAsUpIndicator"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="14dp"
                app:tint="#FFFFFF"/>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvEditTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Edit Match"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tvEditTotalScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#03DAC5"
            android:textSize="40sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" PTS"
            android:textColor="#888888"
            android:textSize="16sp"
            android:layout_marginBottom="4dp"/>

        <View
            android:layout_width="1dp"
            android:layout_height="30dp"
            android:background="#2C2C2E"
            android:layout_marginHorizontal="24dp"/>

        <TextView
            android:id="@+id/tvEditRP"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFC107"
            android:textSize="40sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" RP"
            android:textColor="#888888"
            android:textSize="16sp"
            android:layout_marginBottom="4dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardEditAuto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1A1A1A"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AUTONOMOUS"
                        android:textColor="#BB86FC"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <CheckBox
                            android:id="@+id/cbEditLeave1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Robot 1 Leave"
                            android:textColor="#FFFFFF"
                            android:buttonTint="#BB86FC"/>

                        <CheckBox
                            android:id="@+id/cbEditLeave2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Robot 2 Leave"
                            android:textColor="#FFFFFF"
                            android:buttonTint="#BB86FC"
                            android:layout_marginStart="16dp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="4dp">
                        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Classified" android:textColor="#FFFFFF"/>
                        <Button android:id="@+id/btnMinAC" android:layout_width="48dp" android:layout_height="48dp" android:text="&#x2212;" android:backgroundTint="#2C2C2E" android:textColor="#FFFFFF" app:cornerRadius="24dp" android:textSize="26sp"/>
                        <TextView android:id="@+id/valAC" android:layout_width="40dp" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:gravity="center" android:textSize="22sp" android:textStyle="bold"/>
                        <Button android:id="@+id/btnPlusAC" android:layout_width="48dp" android:layout_height="48dp" android:text="+" android:backgroundTint="#03DAC5" android:textColor="#000000" app:cornerRadius="24dp" android:textSize="26sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="4dp">
                        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Overflow" android:textColor="#FFFFFF"/>
                        <Button android:id="@+id/btnMinAO" android:layout_width="48dp" android:layout_height="48dp" android:text="&#x2212;" android:backgroundTint="#2C2C2E" android:textColor="#FFFFFF" app:cornerRadius="24dp" android:textSize="26sp"/>
                        <TextView android:id="@+id/valAO" android:layout_width="40dp" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:gravity="center" android:textSize="22sp" android:textStyle="bold"/>
                        <Button android:id="@+id/btnPlusAO" android:layout_width="48dp" android:layout_height="48dp" android:text="+" android:backgroundTint="#03DAC5" android:textColor="#000000" app:cornerRadius="24dp" android:textSize="26sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="8dp">
                        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Pattern" android:textColor="#FFFFFF"/>
                        <TextView android:id="@+id/valAP" android:layout_width="40dp" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:gravity="center" android:textSize="22sp" android:textStyle="bold" android:layout_marginEnd="16dp"/>
                        <Button android:id="@+id/btnSelectAP" android:layout_width="wrap_content" android:layout_height="40dp" android:text="SELECT" android:backgroundTint="#BB86FC" android:textColor="#000000" app:cornerRadius="20dp" android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardEditTeleop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1A1A1A"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TELEOP"
                        android:textColor="#03DAC5"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="4dp">
                        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Classified" android:textColor="#FFFFFF"/>
                        <Button android:id="@+id/btnMinTC" android:layout_width="48dp" android:layout_height="48dp" android:text="&#x2212;" android:backgroundTint="#2C2C2E" android:textColor="#FFFFFF" app:cornerRadius="24dp" android:textSize="26sp"/>
                        <TextView android:id="@+id/valTC" android:layout_width="40dp" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:gravity="center" android:textSize="22sp" android:textStyle="bold"/>
                        <Button android:id="@+id/btnPlusTC" android:layout_width="48dp" android:layout_height="48dp" android:text="+" android:backgroundTint="#03DAC5" android:textColor="#000000" app:cornerRadius="24dp" android:textSize="26sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="4dp">
                        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Overflow" android:textColor="#FFFFFF"/>
                        <Button android:id="@+id/btnMinTO" android:layout_width="48dp" android:layout_height="48dp" android:text="&#x2212;" android:backgroundTint="#2C2C2E" android:textColor="#FFFFFF" app:cornerRadius="24dp" android:textSize="26sp"/>
                        <TextView android:id="@+id/valTO" android:layout_width="40dp" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:gravity="center" android:textSize="22sp" android:textStyle="bold"/>
                        <Button android:id="@+id/btnPlusTO" android:layout_width="48dp" android:layout_height="48dp" android:text="+" android:backgroundTint="#03DAC5" android:textColor="#000000" app:cornerRadius="24dp" android:textSize="26sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="4dp">
                        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Depot" android:textColor="#FFFFFF"/>
                        <Button android:id="@+id/btnMinTD" android:layout_width="48dp" android:layout_height="48dp" android:text="&#x2212;" android:backgroundTint="#2C2C2E" android:textColor="#FFFFFF" app:cornerRadius="24dp" android:textSize="26sp"/>
                        <TextView android:id="@+id/valTD" android:layout_width="40dp" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:gravity="center" android:textSize="22sp" android:textStyle="bold"/>
                        <Button android:id="@+id/btnPlusTD" android:layout_width="48dp" android:layout_height="48dp" android:text="+" android:backgroundTint="#03DAC5" android:textColor="#000000" app:cornerRadius="24dp" android:textSize="26sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingVertical="8dp">
                        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Pattern" android:textColor="#FFFFFF"/>
                        <TextView android:id="@+id/valTP" android:layout_width="40dp" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:gravity="center" android:textSize="22sp" android:textStyle="bold" android:layout_marginEnd="16dp"/>
                        <Button android:id="@+id/btnSelectTP" android:layout_width="wrap_content" android:layout_height="40dp" android:text="SELECT" android:backgroundTint="#BB86FC" android:textColor="#000000" app:cornerRadius="20dp" android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardEditEndgame"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1A1A1A"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ENDGAME"
                        android:textColor="#FF5252"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Robot 1 Park"
                        android:textColor="#888888"
                        android:textStyle="bold"/>

                    <RadioGroup
                        android:id="@+id/rgEditPark1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <RadioButton android:id="@+id/rbEditP1None" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="None" android:textColor="#FFFFFF" android:buttonTint="#FF5252"/>
                        <RadioButton android:id="@+id/rbEditP1Part" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Part" android:textColor="#FFFFFF" android:buttonTint="#FF5252"/>
                        <RadioButton android:id="@+id/rbEditP1Full" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Full" android:textColor="#FFFFFF" android:buttonTint="#FF5252"/>
                    </RadioGroup>

                    <LinearLayout
                        android:id="@+id/layoutEditPark2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="16dp">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#2C2C2E"
                            android:layout_marginBottom="16dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Robot 2 Park"
                            android:textColor="#888888"
                            android:textStyle="bold"/>

                        <RadioGroup
                            android:id="@+id/rgEditPark2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="8dp">

                            <RadioButton android:id="@+id/rbEditP2None" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="None" android:textColor="#FFFFFF" android:buttonTint="#FF5252"/>
                            <RadioButton android:id="@+id/rbEditP2Part" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Part" android:textColor="#FFFFFF" android:buttonTint="#FF5252"/>
                            <RadioButton android:id="@+id/rbEditP2Full" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Full" android:textColor="#FFFFFF" android:buttonTint="#FF5252"/>
                        </RadioGroup>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardEditResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1A1A1A"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="20dp">

                <RadioGroup
                    android:id="@+id/rgEditResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center">

                    <RadioButton android:id="@+id/rbEditWin" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="WIN" android:textColor="#FFFFFF" android:buttonTint="#34C759" android:textStyle="bold"/>
                    <RadioButton android:id="@+id/rbEditTie" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="TIE" android:textColor="#FFFFFF" android:buttonTint="#FFCC00" android:textStyle="bold"/>
                    <RadioButton android:id="@+id/rbEditLoss" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="LOSS" android:textColor="#FFFFFF" android:buttonTint="#FF3B30" android:textStyle="bold"/>
                </RadioGroup>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1A1A1A"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="32dp">

                <EditText
                    android:id="@+id/etEditNotes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="100dp"
                    android:hint="Match Notes..."
                    android:textColor="#FFFFFF"
                    android:textColorHint="#888888"
                    android:background="@null"
                    android:padding="20dp"
                    android:gravity="top|start"/>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnCancelEdit"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="64dp"
            android:text="DISCARD"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#1A1A1A"
            android:textColor="#FF3B30"
            app:cornerRadius="32dp"
            android:layout_marginEnd="16dp"/>

        <Button
            android:id="@+id/btnSaveEdit"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:layout_height="64dp"
            android:text="SAVE CHANGES"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#0A7AFF"
            android:textColor="#FFFFFF"
            app:cornerRadius="32dp"/>
    </LinearLayout>
</LinearLayout>